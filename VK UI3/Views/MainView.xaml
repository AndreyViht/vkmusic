<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="VK_UI3.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animations="using:VK_UI3.Helpers.Animations"
    xmlns:controlLyryc="using:VK_UI3.Views.ModalsPages"
    xmlns:custom="using:VK_UI3.Controllers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:krotos="using:KrotosNavigationFrame"
    xmlns:local="using:VK_UI3.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d"
    AutomationProperties.Name="Главная страница приложения"
    AutomationProperties.HelpText="Основная страница приложения с навигацией и плеером">
    <Page.Resources>
        <ThemeShadow x:Name="SharedShadow" />

        <Storyboard x:Name="ExpandAnimation">
            <DoubleAnimation
                EnableDependentAnimation="True"
                Storyboard.TargetName="LyricPage"
                Storyboard.TargetProperty="Opacity"
                To="1"
                Duration="0:0:0.3" />
        </Storyboard>

        <Storyboard x:Name="CollapseAnimation">
            <DoubleAnimation
                EnableDependentAnimation="True"
                Storyboard.TargetName="LyricPage"
                Storyboard.TargetProperty="Opacity"
                To="0"
                Duration="0:0:0.3" />
        </Storyboard>


        <Storyboard x:Name="ExpandAnimationPlayingList">
            <DoubleAnimation
                EnableDependentAnimation="True"
                Storyboard.TargetName="SectionViewPageNowPlayingList"
                Storyboard.TargetProperty="Opacity"
                To="1"
                Duration="0:0:0.3" />
        </Storyboard>

        <Storyboard x:Name="CollapseAnimationPlayingList">
            <DoubleAnimation
                EnableDependentAnimation="True"
                Storyboard.TargetName="SectionViewPageNowPlayingList"
                Storyboard.TargetProperty="Opacity"
                To="0"
                Duration="0:0:0.3" />
        </Storyboard>

    </Page.Resources>


    <Grid AutomationProperties.Name="Основная сетка приложения" AutomationProperties.HelpText="Основная область компоновки приложения">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            AutomationProperties.Name="Область навигации"
            AutomationProperties.HelpText="Основная область навигации приложения">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />

            </Grid.RowDefinitions>

            <NavigationView
                Name="NavWiv"
                Grid.RowSpan="2"
                Margin="0"
                HorizontalAlignment="Stretch"
                IsBackButtonVisible="Collapsed"
                IsBackEnabled="False"
                IsPaneOpen="False"
                IsSettingsVisible="False"
                IsPaneVisible="False"
                PaneDisplayMode="Top"
                AutomationProperties.Name="Навигационное меню"
                AutomationProperties.HelpText="Основное меню навигации приложения">


                <Grid
                    x:Name="MainGridLir"
                    Margin="0"
                    PointerEntered="ListViewItem_PointerEntered"
                    AutomationProperties.Name="Основная область содержимого"
                    AutomationProperties.HelpText="Основная область отображения содержимого приложения">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <!-- Кастомная панель навигации -->
                    <StackPanel Grid.Row="0" x:Name="CustomTopNav" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4" Margin="0,10,0,10">
                        <StackPanel.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </StackPanel.Resources>
                        
                        <Button Tag="Моя музыка" PointerEntered="NavBtn_PointerEntered" PointerExited="NavBtn_PointerExited" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEC4F;" />
                                <TextBlock Text="Моя музыка" Visibility="Collapsed" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="Мои плейлисты" PointerEntered="NavBtn_PointerEntered" PointerExited="NavBtn_PointerExited" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE93C;" />
                                <TextBlock Text="Мои плейлисты" Visibility="Collapsed" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="Плейлисты" PointerEntered="NavBtn_PointerEntered" PointerExited="NavBtn_PointerExited" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEB51;" />
                                <TextBlock Text="Плейлисты" Visibility="Collapsed" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="Музыка друзей" PointerEntered="NavBtn_PointerEntered" PointerExited="NavBtn_PointerExited" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE716;" />
                                <TextBlock Text="Музыка друзей" Visibility="Collapsed" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="Вложения" PointerEntered="NavBtn_PointerEntered" PointerExited="NavBtn_PointerExited" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8F2;" />
                                <TextBlock Text="Вложения" Visibility="Collapsed" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="Для Вас" PointerEntered="NavBtn_PointerEntered" PointerExited="NavBtn_PointerExited" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEC32;" />
                                <TextBlock Text="Для Вас" Visibility="Collapsed" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Tag="Параметры" PointerEntered="NavBtn_PointerEntered" PointerExited="NavBtn_PointerExited" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE713;" />
                                <TextBlock Text="Настройки" Visibility="Collapsed" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <animations:AnimatedSearch
                        x:Name="Search"
                        Grid.Row="1"
                        Height="0"
                        Margin="0"
                        OriginalHeight="50"
                        AutomationProperties.Name="Панель поиска"
                        AutomationProperties.HelpText="Панель для поиска музыки и контента" />
                    <krotos:NavigateFrame x:Name="ContentFrame" Grid.Row="2" AutomationProperties.Name="Фрейм содержимого" AutomationProperties.HelpText="Область отображения основного содержимого" />
                </Grid>
            </NavigationView>
            <controlLyryc:LyricsPage
                x:Name="LyricPage"
                Grid.Row="3"
                VerticalAlignment="Stretch"
                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                Opacity="0"
                Visibility="Collapsed"
                AutomationProperties.Name="Страница текстов песен"
                AutomationProperties.HelpText="Отображает тексты песен для текущего трека" />
            <controlLyryc:EqualizerControl
                x:Name="EqualizerControlPage"
                Grid.Row="3"
                VerticalAlignment="Stretch"
                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                Opacity="0"
                Visibility="Collapsed"
                AutomationProperties.Name="Эквалайзер"
                AutomationProperties.HelpText="Настройка звуковых параметров воспроизведения" />
            <Frame
                x:Name="SectionViewPageNowPlayingList"
                Grid.Row="3"
                VerticalAlignment="Stretch"
                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                Opacity="0"
                Visibility="Collapsed"
                AutomationProperties.Name="Список воспроизведения"
                AutomationProperties.HelpText="Отображает список треков в текущем плейлисте" />
        </Grid>
        <Frame
            Grid.Row="0"
            Margin="16,0,16,16"
            CornerRadius="20"
            VerticalAlignment="Bottom"
            BorderThickness="0"
            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
            BorderBrush="Transparent"
            AutomationProperties.Name="Плеер"
            AutomationProperties.HelpText="Основной музыкальный плеер приложения">
            <custom:AudioPlayer Margin="0" AutomationProperties.Name="Аудио плеер" AutomationProperties.HelpText="Компонент управления воспроизведением музыки" />
        </Frame>
    </Grid>
</Page>
