<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VK_UI3.Views.OverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VK_UI3.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:VK_UI3.WinUI.Controls"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="Transparent" PointerPressed="RootGrid_PointerPressed">
        
        <Grid.Resources>
            <Storyboard x:Name="FadeInAnimation">
                <DoubleAnimation Storyboard.TargetName="ExpandedPanel" 
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.0" To="1.0" Duration="0:0:0.2" />
            </Storyboard>
        </Grid.Resources>

        <!-- Кнопка-состояние (свернуто) -->
        <Grid x:Name="CollapsedButton" 
              Width="60" Height="60" 
              Background="Transparent"
              Tapped="ToggleExpand_Click"
              Visibility="Visible"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              Cursor="Hand">
            <!-- App Logo for collapsed state -->
            <Image Source="ms-appx:///Assets/StoreLogo.scale-400.png" Stretch="UniformToFill" Width="60" Height="60"/>
        </Grid>

        <!-- Развернутое состояние (Мини-плеер) -->
        <Border x:Name="ExpandedPanel" 
                Visibility="Collapsed"
                Background="Transparent"
                BorderThickness="0"
                CornerRadius="12"
                Width="320" Height="420"
                Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Current Track & Controls -->
                    <RowDefinition Height="*"/>    <!-- Next tracks list -->
                </Grid.RowDefinitions>

                <!-- Current Track & Controls -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Width="60" Height="60" CornerRadius="6" Background="#20FFFFFF">
                        <Grid>
                            <FontIcon Glyph="&#xE8D6;" FontSize="24" Foreground="#80FFFFFF" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <Image x:Name="CurrentTrackImage" Stretch="UniformToFill"/>
                        </Grid>
                    </Border>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock x:Name="CurrentTrackTitle" FontWeight="Bold" FontSize="16" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                        <TextBlock x:Name="CurrentTrackArtist" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                    </StackPanel>

                    <Grid Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Right" Tapped="ToggleExpand_Click" Background="Transparent" Padding="5" Cursor="Hand">
                        <FontIcon Glyph="&#xE711;" FontSize="12" FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                    </Grid>

                    <!-- Controls -->
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="25" Margin="0,15,0,5">
                        <Grid Tapped="Prev_Click" Background="Transparent" Padding="10" Cursor="Hand">
                            <FontIcon Glyph="&#xE892;" FontSize="20" FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                        </Grid>
                        <Grid x:Name="PlayPauseButton" Tapped="PlayPause_Click" Background="Transparent" Padding="10" Cursor="Hand">
                            <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" FontSize="28" FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                        </Grid>
                        <Grid Tapped="Next_Click" Background="Transparent" Padding="10" Cursor="Hand">
                            <FontIcon Glyph="&#xE893;" FontSize="20" FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Next Tracks -->
                <ListView Grid.Row="1" x:Name="NextTracksList" SelectionMode="Single" IsItemClickEnabled="True" ItemClick="NextTracksList_ItemClick" ShowsScrollingPlaceholders="False" Background="Transparent">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5" Background="Transparent">
                                <Border Width="40" Height="40" CornerRadius="4" Background="#20FFFFFF">
                                    <Grid>
                                        <FontIcon Glyph="&#xE8D6;" FontSize="20" Foreground="#80FFFFFF" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <Image Source="{Binding Album.Thumb.Photo34}" Stretch="UniformToFill"/>
                                    </Grid>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                                    <TextBlock Text="{Binding Artist}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Window>
